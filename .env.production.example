# ARKS RWA Production Environment Configuration
# Copy this file to .env.production and configure for production deployment

# ============================================
# ADMIN CONFIGURATION (REQUIRED)
# ============================================
# Your production admin principal - MUST be set for production deployment
# Get your principal with: dfx identity get-principal
# This principal will have admin access to all canisters
ADMIN_PRINCIPAL=YOUR_PRODUCTION_ADMIN_PRINCIPAL_HERE

# ============================================
# AI SERVICES (RECOMMENDED)
# ============================================
# SerpAPI key for web research (https://serpapi.com/)
# Required for AI-powered company verification in production
SERPAPI_API_KEY=YOUR_SERPAPI_KEY_HERE

# Google Gemini API key for fraud analysis (https://makersuite.google.com/app/apikey)
# Required for AI-powered fraud detection in production
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ============================================
# PRODUCTION SETTINGS
# ============================================
# DFX Network (must be 'ic' for production)
DFX_NETWORK=ic

# Production domain (if using custom domain)
PRODUCTION_DOMAIN=

# ============================================
# MONITORING & ALERTS (OPTIONAL)
# ============================================
# Webhook URL for deployment notifications
DEPLOYMENT_WEBHOOK_URL=

# Email for critical alerts
ALERT_EMAIL=

# ============================================
# SECURITY NOTES
# ============================================
# 1. Keep this file secure and never commit it to git
# 2. Use a dedicated production identity for deployment
# 3. Regularly rotate API keys
# 4. Monitor canister cycles usage
# 5. Set up alerts for unusual activity

# ============================================
# EXAMPLE VALUES (REPLACE WITH ACTUAL VALUES)
# ============================================
# ADMIN_PRINCIPAL=abc12-def34-ghi56-jkl78-mno90-pqr12-stu34-vwx56-yz789-012ab-cde
# SERPAPI_API_KEY=your_production_serpapi_key_here
# GEMINI_API_KEY=your_production_gemini_key_here
# DEPLOYMENT_WEBHOOK_URL=https://hooks.slack.com/your-webhook-url
# ALERT_EMAIL=admin@yourdomain.com