{
  "canisters": {
    "arks-risk-engine": {
      "main": "src/backend/risk_engine/main.mo",
      "type": "motoko",
      "init_arg": "(null, null, null)",
      "domains": ["*"]
    },
    "frontend": {
      "dependencies": ["arks-risk-engine"],
      "source": ["src/frontend/.next/build"],
       "type": "assets",
       "domains": ["*"]
    },
    "internet_identity": {
      "type": "custom",
      "candid": "https://raw.githubusercontent.com/dfinity/internet-identity/main/src/internet_identity/internet_identity.did",
      "wasm": "https://github.com/dfinity/internet-identity/releases/latest/download/internet_identity_dev.wasm.gz"
    }
  },
  "networks": {
    "local": {
      "bind": "127.0.0.1:4943",             
      "type": "ephemeral",
      "domains": ["*"]
      
    },
    "ic": {
      "providers": ["https://icp-api.io"],
      "type": "persistent"
    }
  },
  "defaults": {
    "build": {
      "args": "",
      "packtool": ""
    }
  },
  "output_env_file": ".env",
  "version": 1
}