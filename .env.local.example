# ARKS RWA Local Development Environment Configuration
# Copy this file to .env.local and configure for your local development

# ============================================
# ADMIN CONFIGURATION
# ============================================
# Your DFX identity principal (optional - defaults to current identity)
# Get your principal with: dfx identity get-principal  
ADMIN_PRINCIPAL=

# ============================================
# AI SERVICES (OPTIONAL)
# ============================================
# SerpAPI key for web research (https://serpapi.com/)
# Required for AI-powered company verification
SERPAPI_API_KEY=

# Google Gemini API key for fraud analysis (https://makersuite.google.com/app/apikey)
# Required for AI-powered fraud detection
GEMINI_API_KEY=

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
# DFX Network (leave as 'local' for development)
DFX_NETWORK=local

# Enable debug logging for deployment scripts
DEBUG_DEPLOYMENT=false

# ============================================
# EXAMPLE VALUES (FOR REFERENCE)
# ============================================
# ADMIN_PRINCIPAL=rg7t5-bghe6-tattl-q7us7-zc57a-2xjvm-r24zv-imqwn-npa36-eso5m-mqe
# SERPAPI_API_KEY=your_serpapi_key_here
# GEMINI_API_KEY=your_gemini_api_key_here